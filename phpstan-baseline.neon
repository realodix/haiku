parameters:
	ignoreErrors:
		-
			rawMessage: 'Method Realodix\Haiku\Config\FixerConfig::resolveFlags() should return array{adg_non_basic_rule_modifier: bool, attr_to_basic_selector: ''loose''|''strict''|null, combine_option_sets: bool, domain_order: ''name''|''negated_first''|''normal''|null, migrate_deprecated_options: bool, no_legacy_ext_selectors: bool, no_legacy_remove_action: bool, normalize_domain: bool, ...} but returns array<string, mixed>.'
			identifier: return.type
			count: 1
