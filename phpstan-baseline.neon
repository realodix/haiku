		-
			rawMessage: 'Property Realodix\Haiku\Config\LinterConfig::$rules (array{cosm_id_selector_start: bool, domain_case: bool, net_pattern_anchor: bool, no_dupe_domains: bool, no_dupe_options: bool, no_dupe_rules: bool, no_extra_blank_lines: bool|int, no_short_rules: bool|int, ...}) does not accept array<string, mixed>.'
			identifier: assign.propertyType
			count: 1
			path: src/Config/LinterConfig.php

